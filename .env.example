# opensips-deploy-local env overrides.
# Copy to .env and edit, or export before `docker compose up`.

# MySQL creds used by the deploy scripts when talking to the TARGET box.
# Must match a user that can CREATE/DROP/INSERT on the opensips DB there.
DB_USER=root
DB_PASS=change_me
DB_NAME=opensips

# Path inside the container where the bundle lives. Normally you don't
# need to change this - compose mounts ./bundle here read-only.
# BUNDLE_DIR=/var/www/html/opensips-deploy/bundle

# If port 8080 is taken on your machine, change the host side in
# docker-compose.yml (left side of "8080:80").
