# opensips-deploy-local env overrides.
# Copy to .env and adjust values, or export before running `docker compose up`.

# MySQL credentials used by deploy scripts when talking to the TARGET's MySQL.
# These must match the user that has `CREATE/DROP/INSERT` on the opensips DB
# on the target server you are deploying to.
DB_USER=root
DB_PASS=change_me
DB_NAME=opensips

# Override if the bundle/ directory lives somewhere other than the default.
# BUNDLE_DIR=/var/www/html/opensips-deploy/bundle

# Override the HTTP port the container exposes (host side).
# Default 8080 is used in docker-compose.yml; change the compose file to apply.
# HOST_PORT=8080
