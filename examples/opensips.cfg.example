							$var(new_ip)="207.121.58.80";		
							xlog(" [MEDIA IP]  NEW/OLD IP CONFIGURATION <<< >>> <<< >>> : $var(new_ip)");
						}
						$var(new_sdp) = replace_body_all($var(old_ip),$var(new_ip));
   						xlog(" [MEDIA IP]  NEW SDP  <<< >>> <<< >>> : $var(new_sdp)");
   						$var(body)=$rb;
    					xlog(" [MEDIA IP] Body BEFORE <<< >>> <<< >>> : $var(body) \n \s");
    				}
					if (t_check_status("200")) {
						$var(new_ip)=$avp(media_ip);
   						xlog(" [MEDIA IP]  NEW SDP  <<< >>> <<< >>> : $var(new_ip)");

						$var(old_ip)=$si;
