		   xlog("[183] PLAY Media INVITE \n| $$var(body): $var(body) \n| totag: $ft \n| from-tag: $ft | $$si: $si contact: $ct $$rd: $rd \n");

		   t_reply_with_body(183, "Session Progress", $var(body));
		   route(relay);
}

route[relay] {

	# for INVITEs enable some additional helper routes
	if (is_method("INVITE")) {

		#if (isflagset("NAT") && has_body("application/sdp")) {
			#rtpengine_offer();
		#}

		t_on_branch("per_branch_ops");
		t_on_reply("handle_nat");
		t_on_failure("missed_call");
	}


### END
	if (isflagset("NAT")) {
		add_rr_param(";nat=yes");
	}

	if (!t_relay()) {
		send_reply(500,"Internal Error");
	}
	exit;
}

branch_route[per_branch_ops] {
		xlog("new branch at $ru\n");
		xlog(" [MEDIA IP] Received 183 OK response for INVITE: $T_reply_code");
}


onreply_route[handle_nat] {
	if (nat_uac_test(1))
		fix_nated_contact();
	#if ( isflagset("NAT") && has_body("application/sdp") )

			#remove_body_part();
			#remove_body_part($var(body));
			$var(body)=$rb;

    		$avp(env) = "a";
			$avp(env) = "b";
			exec("/usr/bin/bash /etc/opensips/getip.sh '$var(body)'", ,$var(out),$var(err),$avp(env));
			xlog("The output is $var(out)");

			xlog(" [MEDIA IP] Received CODE response : $T_reply_code");

        xlog("Modified SDP Body: $var(body)\n");
		### END

			if ($var(re-invite)=="re-INVITE") {
				if (t_check_status("200")) {
					#if (search_body("74\\.222\\.1\\.34")) {
