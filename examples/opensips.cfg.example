local_route {
	if (is_method("BYE")) {
		# Update call end time for all BYEs
		avp_db_query("UPDATE call_recordings SET end_time=NOW(), duration_sec=TIMESTAMPDIFF(SECOND,start_time,NOW()) WHERE call_id='$ci'");

		# Trigger post-processing

		# Original accounting
		if ($DLG_dir=="UPSTREAM") {
			acc_db_request("200 Dialog Timeout", "acc");
		}
	}
}


