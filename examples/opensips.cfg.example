failure_route[missed_call] {
	# Log call end for failed calls
	if (!t_was_cancelled()) {
		avp_db_query("UPDATE call_recordings SET end_time=NOW(), duration_sec=TIMESTAMPDIFF(SECOND,start_time,NOW()) WHERE call_id='$ci'");
	}

	if (t_was_cancelled()) {
		exit;
	}

	# uncomment the following lines if you want to block client 
	# redirect based on 3xx replies.
