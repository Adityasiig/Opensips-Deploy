#!/bin/bash

# Assuming the text is stored in a variable named text_content
text_content=$1

# Using grep to extract IP addresses from the variable
ip_addresses=$(echo "$text_content" | grep -E -o "([0-9]{1,3}[\.]){3}[0-9]{1,3}")

# Print the extracted IP addresses
#echo "$ip_addresses"

# Splitting the IP addresses using read
{
  read -r ip1
  read -r ip2
} <<< "$ip_addresses"

# Printing the separated IP addresses
#echo -e "\nSeparated IP addresses:"
echo "$ip1"
#echo "IP 2: $ip2"
